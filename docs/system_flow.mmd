flowchart TB
    subgraph User["用户层"]
        U[用户输入自然语言查询]
    end

    subgraph Retrieval["检索层"]
        E[Embedding 模型<br/>将用户问题编码为向量]
        V[(向量数据库<br/>ChromaDB/Milvus)]
        R[Top-K 表检索<br/>基于表描述相似度]
        F[获取完整表信息<br/>字段+使用说明]
    end

    subgraph Storage["存储层"]
        TD[(表描述向量)]
        TI[(表详细信息<br/>JSON/Text)]
    end

    subgraph AgentLayer["Agent 协作层"]
        subgraph Agent1["Agent 1: 字段提取专家"]
            A1_INPUT[输入: 用户问题 + 多表完整信息]
            A1_PROCESS[分析用户意图<br/>匹配相关字段<br/>识别表关系]
            A1_OUTPUT[输出: 精简字段信息<br/>相关表关系图]
        end

        subgraph Agent2["Agent 2: SQL 生成专家"]
            A2_INPUT[输入: 精简字段 + 原始问题]
            A2_PROCESS[构建查询逻辑<br/>选择 JOIN 策略<br/>生成 SQL 语法]
            A2_OUTPUT[输出: 完整 SQL 语句<br/>执行计划说明]
        end
    end

    subgraph Output["输出层"]
        VALIDATE[SQL 语法校验]
        RESULT[返回: SQL + 解释]
    end

    %% 流程连接
    U --> E
    E --> V
    V --> TD
    TD --> R
    R --> F
    TI --> F
    F --> A1_INPUT
    A1_INPUT --> A1_PROCESS
    A1_PROCESS --> A1_OUTPUT
    A1_OUTPUT --> A2_INPUT
    A2_INPUT --> A2_PROCESS
    A2_PROCESS --> A2_OUTPUT
    A2_OUTPUT --> VALIDATE
    VALIDATE --> RESULT

    %% 样式定义
    style U fill:#e1f5fe
    style E fill:#fff3e0
    style V fill:#f3e5f5
    style TD fill:#f3e5f5
    style TI fill:#e8f5e9
    style A1_PROCESS fill:#ffebee
    style A2_PROCESS fill:#ffebee
    style RESULT fill:#e8f5e9

    %% 注释说明
    note1["关键设计: 表描述向量化<br/>字段信息文本化"]
    note2["关键设计: 两阶段 Agent<br/>先提取后生成"]
    
    style note1 fill:#fff9c4
    style note2 fill:#fff9c4
